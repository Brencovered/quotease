# Supabase — create a project at supabase.com, run supabase/schema.sql in its SQL editor
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Resend — for the "send quote" email feature. Sign up at resend.com,
# verify a sending domain, create an API key.
RESEND_API_KEY=
RESEND_FROM_EMAIL=quotes@yourdomain.com

# Xero — register a developer app at developer.xero.com/app/manage.
# Set the redirect URI there to exactly match XERO_REDIRECT_URI below.
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=https://your-deployment.vercel.app/api/xero/callback

# Stripe — $40/mo flat or $400/yr, unlimited users, 7-day trial.
# Create the two recurring Prices in the Stripe dashboard first (Products > Add product),
# then paste their price IDs (not product IDs) below.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=
NEXT_PUBLIC_APP_URL=https://your-deployment.vercel.app

# Anthropic API — powers "estimate from a drawing" in the quote builder.
# Get a key at console.anthropic.com. Each analysis is a single API call
# with an image/PDF attached - cheap, but a real per-use cost, not free.
ANTHROPIC_API_KEY=

# Supabase service role key — required by the Stripe webhook to update
# subscription status (it has no logged-in user, so it can't use the anon key).
# Find this in Supabase: Project Settings > API > service_role key.
# NEVER expose this to the browser or commit it.
SUPABASE_SERVICE_ROLE_KEY=
